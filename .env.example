# NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=your_nvapi_key_here
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_VL_MODEL=nvidia/nemotron-nano-12b-v2-vl
# moonshotai/kimi-k2.6 — uses json_object + thinking=false (see process_bulletin_board.py)
# NIM_MAX_TOKENS=8192
# NIM_STREAM=1          # 1=stream tokens to terminal (default), 0=wait for full response
# NIM_THINKING=0        # Kimi only: 1 enables reasoning (may 500 on NIM); default off

# MongoDB (localhost when running on host; Docker Compose overrides to mongodb://mongo:27017)
MONGO_URI=mongodb://localhost:27017
# MONGO_TIMEOUT_MS=5000
# LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG   # verbose: dedup details, MongoDB debug, full NIM traces

# Image encoding for NIM (jpeg or png). PNG also saves to input/converted/
# IMAGE_OUTPUT_FORMAT=png
MONGO_DB=uniroom-data
MONGO_COLLECTION=housing_listings
MONGO_FILES_COLLECTION=reviewed_files

# Telegram bot — create via https://t.me/BotFather, then run: python telegram_bot.py
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_UPLOAD_DIR=input/telegram
